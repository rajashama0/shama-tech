#!/usr/bin/env python3
import importlib.util
import os
import sys
from runpy import run_path


server_dir = os.path.abspath(os.path.join(os.path.dirname(__file__), ".."))
apis_dir = os.path.join(server_dir, "apis")

sys.path.insert(0, server_dir)
sys.path.insert(0, apis_dir)


def json_error(code, message):
    return '{"server":{"allow":0,"success":false,"error":{"code":"' + code + '","message":"' + message + '"}}}'


def load_config():
    path = os.path.join(server_dir, "config.py")
    spec = importlib.util.spec_from_file_location("config", path)
    config = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(config)
    return config


def cors_origin(config):
    origin = os.environ.get("HTTP_ORIGIN", "")
    allowed = getattr(config, "FRONTEND_ORIGINS", [])
    if allowed == ["*"]:
        return "*"
    if origin in allowed:
        return origin
    if allowed:
        return allowed[0]
    return "*"


config = None
config_error = ""
try:
    config = load_config()
except Exception:
    config_error = "server configuration error"

allow_origin = "*"
if config is not None:
    allow_origin = cors_origin(config)

print("Content-Type: application/json")
print(f"Access-Control-Allow-Origin: {allow_origin}")
print("Access-Control-Allow-Methods: POST, OPTIONS")
print("Access-Control-Allow-Headers: Content-Type, X-Admin-Token")
print("Access-Control-Max-Age: 86400")
print("Vary: Origin")
print("")

method = os.environ.get("REQUEST_METHOD", "GET")

if method == "OPTIONS":
    print('{"server":{"allow":1,"success":true,"data":{"ok":1}}}')
elif method != "POST":
    print(json_error("method_not_allowed", "use POST"))
elif config_error:
    print(json_error("config_error", config_error))
else:
    api_path = os.path.join(apis_dir, "cgi.py")
    try:
        run_path(api_path)
    except Exception:
        print(json_error("internal_error", "internal api error"))
